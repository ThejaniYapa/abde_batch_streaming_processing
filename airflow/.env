# On Linux hosts (e.g. EC2), Airflow writes logs to the mounted ./logs folder as
# this UID so the files stay owned by you. 50000 is the airflow user's default.
# Linux users: run `echo "AIRFLOW_UID=$(id -u)" >> .env` to match your own user.
# macOS / Windows (Docker Desktop): the default below is fine.
AIRFLOW_UID=50000
